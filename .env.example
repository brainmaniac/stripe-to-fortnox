# Generate with: htpasswd -bnBC 10 "" 'yourpassword' | tr -d ':\n' | sed 's/$2y/$2a/'
ADMIN_PASSWORD_HASH=$2a$10$...

# Generate a random 32-byte hex string: openssl rand -hex 32
SESSION_SECRET=your-random-32-byte-hex-string-here

# Stripe API credentials
STRIPE_API_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Fortnox OAuth2 credentials (from Fortnox developer portal)
FORTNOX_CLIENT_ID=
FORTNOX_CLIENT_SECRET=

# Base URL for OAuth callbacks (no trailing slash)
BASE_URL=http://localhost:8080
